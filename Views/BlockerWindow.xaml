<Window
    x:Class="Unbreakfocus.Views.BlockerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="Black">
        <Grid>
            <Grid.Background>
                <RadialGradientBrush Center="0.5,0.5" RadiusX="1.2" RadiusY="1.2">
                    <GradientStop Color="Black" Offset="0.45"/>
                    <GradientStop Color="#CCEF4444" Offset="1.0"/> </RadialGradientBrush>
            </Grid.Background>
        </Grid>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="24">
            
            <Grid HorizontalAlignment="Center">
                <Ellipse Width="120" Height="120" Fill="#33EF4444" Stroke="#EF4444" StrokeThickness="2"/>
                <FontIcon Glyph="&#xE72E;" FontSize="60" Foreground="White" /> </Grid>

            <TextBlock Text="FOCUS BREACHED" 
                       FontSize="48" 
                       FontWeight="Black" 
                       Foreground="White" 
                       CharacterSpacing="400" 
                       HorizontalAlignment="Center"/>

            <Border Background="#B2000000" BorderBrush="#7FEF4444" BorderThickness="1.5" CornerRadius="16" Padding="32" MaxWidth="500">
                <StackPanel Spacing="16">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                        <FontIcon Glyph="&#xE7BA;" Foreground="#EF4444" FontSize="16"/>
                        <TextBlock Text="SYSTEM WARNING" Foreground="#EF4444" FontWeight="Black" CharacterSpacing="200"/>
                    </StackPanel>
                    
                    <MenuFlyoutSeparator Background="#33EF4444"/>
                    
                    <TextBlock Text="Shielding mode is currently ACTIVE." Foreground="LightGray" TextAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
                        <TextBlock Text="Restricted access to:" Foreground="LightGray"/>
                        <TextBlock x:Name="BlockedAppNameText" Text="UNKNOWN APP" Foreground="White" FontWeight="Black" CharacterSpacing="100"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Button x:Name="OverrideBtn" Content="OVERRIDE SHIELD" 
                    Click="OverrideBtn_Click" 
                    Background="Transparent" 
                    Foreground="Gray" 
                    BorderBrush="Gray" 
                    BorderThickness="1" 
                    HorizontalAlignment="Center" 
                    Margin="0,40,0,0" 
                    Padding="32,12" 
                    CornerRadius="8"/>
        </StackPanel>
    </Grid>
</Window>