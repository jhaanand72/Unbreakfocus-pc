<Page
    x:Class="Unbreakfocus.Views.HubPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent"
    Loaded="Page_Loaded">

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="HUB" FontSize="32" FontWeight="Black" CharacterSpacing="200" Margin="0,0,0,32" Foreground="White"/>

        <StackPanel Grid.Row="1" Spacing="24">
            
            <Border CornerRadius="16" BorderBrush="#33FFFFFF" BorderThickness="1">
                <Border.Background>
                    <AcrylicBrush TintColor="{StaticResource CardBg}" TintOpacity="0.7" FallbackColor="{StaticResource CardBg}"/>
                </Border.Background>
                <Grid Padding="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Ellipse Width="80" Height="80" Fill="#3338BDF8" Stroke="{StaticResource SkyBlue}" StrokeThickness="2" VerticalAlignment="Center"/>
                    <FontIcon Glyph="&#xE77B;" FontSize="32" Foreground="{StaticResource SkyBlue}" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="24,0,0,0"/>

                    <StackPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="ProfileNameText" Text="ASPIRANT" FontSize="20" FontWeight="Bold" CharacterSpacing="100"/>
                        <TextBlock x:Name="TargetText" Text="TARGET: CUSTOM" Foreground="{StaticResource SkyBlue}" FontSize="12" FontWeight="Bold" CharacterSpacing="150" Margin="0,4,0,12"/>
                        
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:Name="LevelText" Text="LEVEL 1" FontWeight="Black" Foreground="{StaticResource Amber}"/>
                            <TextBlock x:Name="XpText" Text="(0 XP)" Foreground="LightGray"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="16" BorderBrush="#33FB923C" BorderThickness="1">
                    <Border.Background>
                        <AcrylicBrush TintColor="{StaticResource CardBg}" TintOpacity="0.7" FallbackColor="{StaticResource CardBg}"/>
                    </Border.Background>
                    <StackPanel HorizontalAlignment="Center" Padding="32">
                        <FontIcon Glyph="&#xE73E;" Foreground="{StaticResource Orange}" FontSize="40" Margin="0,0,0,16"/>
                        <TextBlock x:Name="StreakText" Text="0 DAYS" FontSize="28" FontWeight="Black" HorizontalAlignment="Center"/>
                        <TextBlock Text="CURRENT STREAK" FontSize="11" Foreground="Gray" FontWeight="Bold" CharacterSpacing="150" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" CornerRadius="16" BorderBrush="#3334D399" BorderThickness="1">
                    <Border.Background>
                        <AcrylicBrush TintColor="{StaticResource CardBg}" TintOpacity="0.7" FallbackColor="{StaticResource CardBg}"/>
                    </Border.Background>
                    <StackPanel HorizontalAlignment="Center" Padding="32">
                        <FontIcon Glyph="&#xE823;" Foreground="{StaticResource Emerald}" FontSize="40" Margin="0,0,0,16"/>
                        <TextBlock x:Name="TotalTimeText" Text="0h 0m" FontSize="28" FontWeight="Black" HorizontalAlignment="Center"/>
                        <TextBlock Text="LIFETIME FOCUS" FontSize="11" Foreground="Gray" FontWeight="Bold" CharacterSpacing="150" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </Grid>
</Page>