<Page
    x:Class="Unbreakfocus.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Unbreakfocus.Models"
    Background="Transparent"
    Loaded="Page_Loaded">

    <Page.Resources>
        <SolidColorBrush x:Key="SkyBlueBrush" Color="#38BDF8"/>
        <SolidColorBrush x:Key="EmeraldBrush" Color="#34D399"/>
        <SolidColorBrush x:Key="CardBackground" Color="#1E1E1E"/>
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,24">
            <StackPanel>
                <TextBlock x:Name="GreetingText" Text="Hi, Aspirant" FontSize="20" FontWeight="Bold"/>
                <TextBlock x:Name="MissionText" Text="MISSION: Custom" Foreground="Gray" FontSize="12" CharacterSpacing="100" FontWeight="SemiBold"/>
                <TextBlock x:Name="DaysLeftText" Text="30 DAYS TO TARGET" Foreground="{StaticResource SkyBlueBrush}" FontSize="24" FontFamily="Consolas" FontWeight="Black" Margin="0,8,0,0"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Spacing="12">
                <Button x:Name="DeleteModeBtn" Click="DeleteModeBtn_Click" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Toggle Delete Mode">
                    <FontIcon Glyph="&#xE74D;" /> </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" CornerRadius="16" Margin="0,0,0,24" BorderBrush="#33FFFFFF" BorderThickness="1">
            <Border.Background>
                <AcrylicBrush TintColor="#161616" TintOpacity="0.8" FallbackColor="#161616"/>
            </Border.Background>
            <StackPanel Padding="20" Spacing="16">
                <Grid>
                    <TextBlock x:Name="TodayTimeText" Text="0h 0m 0s TODAY" FontSize="18" FontWeight="Bold"/>
                    <TextBlock x:Name="PercentCompleteText" Text="0% COMPLETE" Foreground="{StaticResource SkyBlueBrush}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                </Grid>
                
                <ProgressBar x:Name="DailyProgressBar" Maximum="100" Value="0" Foreground="{StaticResource SkyBlueBrush}" CornerRadius="4"/>
                
                <Border CornerRadius="8" Background="#1A34D399" BorderBrush="{StaticResource EmeraldBrush}" BorderThickness="1" Padding="12,8">
                    <Grid>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE73E;" Foreground="{StaticResource EmeraldBrush}" FontSize="16"/>
                            <TextBlock x:Name="StreakStatusText" Text="STREAK SECURED" Foreground="{StaticResource EmeraldBrush}" FontWeight="Bold" FontSize="12"/>
                        </StackPanel>
                        <TextBlock x:Name="StreakPercentText" Text="100%" Foreground="{StaticResource EmeraldBrush}" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
                <TextBlock Text="YOUR SUBJECTS" FontWeight="Bold" Foreground="Gray" VerticalAlignment="Center"/>
                <Button Content="+ Add Subject" Background="{StaticResource SkyBlueBrush}" Foreground="Black" FontWeight="Bold" CornerRadius="8" Click="AddSubject_Click"/>
            </StackPanel>

            <StackPanel x:Name="EmptyStatePanel" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12" Visibility="Collapsed">
                <FontIcon Glyph="&#xE70F;" FontSize="48" Foreground="Gray"/>
                <TextBlock Text="NO SUBJECTS FOUND" FontWeight="Bold" Foreground="Gray" LetterSpacing="100"/>
                <TextBlock Text="Click '+ Add Subject' to begin." Foreground="DarkGray"/>
            </StackPanel>

            <ListView x:Name="SubjectListView" 
                      Grid.Row="1" 
                      CanReorderItems="True" 
                      AllowDrop="True" 
                      SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Subject">
                        <Border CornerRadius="12" Background="{ThemeResource CardBackground}" Margin="0,0,0,12" Padding="16" BorderBrush="#22FFFFFF" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="4">
                                    <TextBlock Text="{x:Bind Name}" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock Text="{x:Bind GoalMins}" Foreground="Gray" FontSize="12"/>
                                    <ProgressBar Maximum="{x:Bind GoalMins}" Value="0" Foreground="{StaticResource SkyBlueBrush}" Margin="0,4,20,0"/> </StackPanel>

                                <Button Grid.Column="1" Background="Transparent" BorderThickness="0" Margin="0,0,12,0" Foreground="Red" 
                                        Click="DeleteSubject_Click" Tag="{x:Bind Id}" Visibility="Collapsed" x:Name="ListItemDeleteBtn">
                                    <FontIcon Glyph="&#xE74D;" FontSize="16"/>
                                </Button>

                                <Button Grid.Column="2" Background="{StaticResource SkyBlueBrush}" CornerRadius="20" Width="40" Height="40" Padding="0" Click="StartTimer_Click" Tag="{x:Bind Id}">
                                    <FontIcon Glyph="&#xE768;" Foreground="Black" FontSize="16"/>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <ContentDialog x:Name="AddSubjectDialog" 
                       Title="NEW SUBJECT" 
                       PrimaryButtonText="ADD" 
                       CloseButtonText="CANCEL" 
                       DefaultButton="Primary" 
                       PrimaryButtonClick="AddSubjectDialog_PrimaryButtonClick">
            <StackPanel Spacing="16" Margin="0,16,0,0">
                <TextBox x:Name="NewSubjectNameInput" Header="SUBJECT NAME" PlaceholderText="e.g. Mathematics"/>
                <NumberBox x:Name="NewSubjectGoalInput" Header="DAILY GOAL (MINS)" Value="60" Minimum="1" Maximum="1440" SpinButtonPlacementMode="Inline"/>
            </StackPanel>
        </ContentDialog>

    </Grid>
</Page>