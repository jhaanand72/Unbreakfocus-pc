<Page
    x:Class="Unbreakfocus.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent"
    Loaded="Page_Loaded">

    <ScrollViewer>
        <StackPanel Margin="32" Spacing="32" MaxWidth="800" HorizontalAlignment="Left">
            
            <TextBlock Text="SYSTEM PREFERENCES" FontSize="32" FontWeight="Black" CharacterSpacing="200" Foreground="White"/>

            <StackPanel Spacing="16">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE77B;" Foreground="{StaticResource SkyBlue}" FontSize="16"/>
                    <TextBlock Text="USER PROFILE" Foreground="{StaticResource SkyBlue}" FontWeight="Bold" CharacterSpacing="150"/>
                </StackPanel>

                <Border CornerRadius="12" Background="#1E1E1E" Padding="24" BorderBrush="#33FFFFFF" BorderThickness="1">
                    <StackPanel Spacing="20">
                        <TextBox x:Name="NameInput" Header="NAME" PlaceholderText="Enter your name" TextChanged="Profile_Changed"/>
                        
                        <ComboBox x:Name="TargetDropdown" Header="MISSION OBJECTIVE" HorizontalAlignment="Stretch" SelectionChanged="Profile_Changed">
                            <x:String>Class 10th ICSE</x:String>
                            <x:String>Class 10th CBSE</x:String>
                            <x:String>Class 12</x:String>
                            <x:String>JEE Mains</x:String>
                            <x:String>JEE Advanced</x:String>
                            <x:String>NEET</x:String>
                            <x:String>UPSC</x:String>
                            <x:String>Custom</x:String>
                        </ComboBox>

                        <TextBox x:Name="CustomTargetInput" Header="CUSTOM TARGET" Visibility="Collapsed" TextChanged="Profile_Changed"/>
                        
                        <CalendarDatePicker x:Name="TargetDatePicker" Header="TARGET DATE" HorizontalAlignment="Stretch" DateChanged="TargetDatePicker_DateChanged"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="16">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE713;" Foreground="{StaticResource SkyBlue}" FontSize="16"/>
                    <TextBlock Text="APP SETTINGS &amp; MODES" Foreground="{StaticResource SkyBlue}" FontWeight="Bold" CharacterSpacing="150"/>
                </StackPanel>

                <Border CornerRadius="12" Background="#1E1E1E" Padding="24" BorderBrush="#33FFFFFF" BorderThickness="1">
                    <StackPanel Spacing="16">
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Width="40" Height="40" CornerRadius="20" Background="#33EF4444" Margin="0,0,16,0">
                                <FontIcon Glyph="&#xE72E;" Foreground="{StaticResource BrightRed}" FontSize="18"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Strict Mode" Foreground="{StaticResource BrightRed}" FontWeight="Bold" FontSize="16"/>
                                <TextBlock Text="Locks Focus Engine. Sessions cannot be aborted." Foreground="Gray" FontSize="12" TextWrapping="Wrap"/>
                            </StackPanel>

                            <ToggleSwitch x:Name="StrictModeToggle" Grid.Column="2" Toggled="StrictModeToggle_Toggled" OnContent="" OffContent=""/>
                        </Grid>

                    </StackPanel>
                </Border>
            </StackPanel>
            
        </StackPanel>
    </ScrollViewer>
</Page>