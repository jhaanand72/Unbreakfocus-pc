<Application
    x:Class="Unbreakfocus.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            
            <SolidColorBrush x:Key="PureBlack" Color="#0A0A0A"/>
            <SolidColorBrush x:Key="CardBg" Color="#161616"/>
            <SolidColorBrush x:Key="SkyBlue" Color="#38BDF8"/>
            <SolidColorBrush x:Key="LightBlue" Color="#818CF8"/>
            <SolidColorBrush x:Key="Emerald" Color="#34D399"/>
            <SolidColorBrush x:Key="Orange" Color="#FB923C"/>
            <SolidColorBrush x:Key="BrightRed" Color="#EF4444"/>
            <SolidColorBrush x:Key="Amber" Color="#FBBF24"/>
            
            <ElementTheme x:Key="DefaultTheme">Dark</ElementTheme>
        </ResourceDictionary>
    </Application.Resources>
</Application>